{
  "name": "pi-fast-apply",
  "version": "0.1.0",
  "description": "Morph Fast Apply for Pi — semantic file editing with partial code snippets, no exact string matching required.",
  "license": "MIT",
  "author": "Victor Software House",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-software-house/pi-fast-apply.git"
  },
  "homepage": "https://github.com/victor-software-house/pi-fast-apply#readme",
  "bugs": {
    "url": "https://github.com/victor-software-house/pi-fast-apply/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "morph",
    "fast-apply",
    "code-editing"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "image": "https://raw.githubusercontent.com/victor-software-house/pi-fast-apply/main/assets/preview.png"
  },
  "type": "module",
  "files": [
    "extensions",
    "assets/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:biome && bun run lint:oxlint",
    "lint:biome": "biome check .",
    "lint:oxlint": "oxlint --import-plugin --type-aware --tsconfig=./tsconfig.json .",
    "fix": "bun run fix:oxlint && bun run fix:biome",
    "fix:biome": "biome check --write .",
    "fix:oxlint": "oxlint --fix --import-plugin --type-aware --tsconfig=./tsconfig.json .",
    "format": "biome format --write .",
    "prepare": "lefthook install"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "@morphllm/morphsdk": "^0.2.163",
    "@sinclair/typebox": "^0.34.49",
    "ai": ">=5.0.0",
    "pi-diff": "github:victor-software-house/pi-diff"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@limegrass/eslint-plugin-import-alias": "^1.6.1",
    "@mariozechner/pi-coding-agent": "^0.63.0",
    "@mariozechner/pi-tui": "^0.63.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^24.3.0",
    "eslint-plugin-zod": "^3.5.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.19.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
